# =============================================
# Server Configuration
# =============================================
PORT=3000

# =============================================
# Security
# =============================================
# Secret token that the Evolution API must send in the header
# x-webhook-secret or Authorization: Bearer <value>
WEBHOOK_SECRET=your_strong_secret_here

# Secret token to protect the administrative endpoints (/api/admin)
ADMIN_API_KEY=your_admin_secret_here

# WhatsApp Group JID to receive moderation alerts (e.g. 1203630XXXXXXX@g.us)
ADMIN_GROUP_JID=1203630XXXXXXX@g.us

# =============================================
# Firebase Admin SDK
# =============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# The private key from your service account JSON.
# Replace actual newlines with \n when pasting here.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END RSA PRIVATE KEY-----"

# =============================================
# Google Cloud Platform (Vertex AI)
# =============================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# =============================================
# Evolution API
# =============================================
EVOLUTION_API_URL=https://your-evolution-api-host.com
EVOLUTION_API_KEY=your_evolution_api_key_here
