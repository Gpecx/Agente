# =============================================
# Server Configuration
# =============================================
PORT=3000

# =============================================
# Security
# =============================================
# Secret token that the Evolution API must send in the header
# x-webhook-secret or Authorization: Bearer <value>
WEBHOOK_SECRET=your_strong_secret_here

# Secret token to protect the administrative endpoints (/api/admin)
ADMIN_API_KEY=your_admin_secret_here

# WhatsApp Group JID to receive moderation alerts (e.g. 1203630XXXXXXX@g.us)
ADMIN_GROUP_JID=1203630XXXXXXX@g.us

# =============================================
# Firebase Admin SDK
# =============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# The private key from your service account JSON.
# Replace actual newlines with \n when pasting here.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END RSA PRIVATE KEY-----"

# =============================================
# Google Cloud Platform (Vertex AI)
# =============================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# =============================================
# Evolution API
# =============================================
EVOLUTION_API_URL=https://your-evolution-api-host.com
EVOLUTION_API_KEY=your_evolution_api_key_here
# Nome da instância da Evolution (necessário para ações disparadas por CRON,
# que não recebem o payload do webhook).
EVOLUTION_INSTANCE=minha-instancia

# =============================================
# Módulo Bot Webinars
# =============================================
# JID do grupo onde o bot posta teasers/enquetes proativamente (CRON).
WEBINAR_GROUP_JID=1203630XXXXXXX@g.us

# JID (pessoa ou grupo) que recebe o relatório CSV semanal (sexta 18h).
# Se vazio, cai no ADMIN_GROUP_JID.
ADMIN_REPORT_JID=5511999999999@s.whatsapp.net

# Liga/desliga o scheduler (crons). Default: true.
WEBINAR_SCHEDULER_ENABLED=true

# Emoji de reação usado como OPT-IN para lembretes via DM.
WEBINAR_OPTIN_EMOJI=🔥

# Lista de palavras proibidas (separadas por vírgula, case-insensitive).
WEBINAR_PALAVROES=palavrao1,palavrao2

# Allowlist de domínios permitidos em links (o resto é tratado como link não autorizado).
WEBINAR_DOMINIOS_PERMITIDOS=youtube.com,youtu.be,zoom.us

# % mínimo de presença para liberar o certificado (0.0 a 1.0). Default 0.8 (80%).
WEBINAR_PRESENCA_MINIMA=0.8

# Janelas dos estados, em horas relativas a data_hora (defaults seguros).
WEBINAR_AQUECIMENTO_H=168   # início do AQUECIMENTO (D-7)
WEBINAR_DIAD_H=1            # início do DIA D (1h antes)
WEBINAR_COLETA_H=48         # fim da COLETA (D+2)

# Anti-ban: delays humanizados entre DMs em lote (ms).
WEBINAR_DM_DELAY_MIN_MS=1200
WEBINAR_DM_DELAY_JITTER_MS=2500

# Duração do "mute" simulado (ms). Default 600000 (10 min).
WEBINAR_MUTE_MS=600000

# Janela "membro recente" (dias) que também recebe lembrete de DIA D.
WEBINAR_MEMBRO_RECENTE_DIAS=30

# Link do e-book entregue no pós-evento (/ebook).
WEBINAR_EBOOK_URL=https://seu-dominio.com/ebook.pdf

# Link de documentação usado nas respostas de FAQ.
WEBINAR_DOCS_URL=https://seu-dominio.com/docs

# Base de FAQ (JSON). Vazio = recurso desligado (não responde dúvidas).
# Ex.: [{"keywords":["certificado"],"resposta":"Exige 80% de presença.","link":"https://docs..."}]
WEBINAR_FAQ=

# ⚠️ RISCO ANTI-BAN: se 'true', envia DM de boas-vindas a quem entrou no grupo
# (mesmo sem opt-in). Padrão 'false' (boas-vindas vão no grupo). Use com cautela.
WEBINAR_WELCOME_DM=false
